# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase (client-side — safe to expose anon key)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# APP_URL: The URL where this app is hosted (Twilio webhooks, OAuth callbacks)
APP_URL="http://localhost:3000"

# Twilio Credentials for outbound phone calling
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ElevenLabs API Credentials for Model B Voice Synthesis
ELEVENLABS_API_KEY=
